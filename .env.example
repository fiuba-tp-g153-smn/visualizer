# Production environment variables
# Copy this file to .env.production and adjust values for production

# Backend API base URL
BACKEND_BASE_URL=http://localhost:6006

# Whether to use mock tiles instead of real API
USE_MOCK_TILES=false

# Tile format (webp or png)
TILE_FORMAT=webp

# App host port (the exposed port of the server)
APP_HOST_PORT=6010

# Docs Service
DOCS_HOST_PORT=6011
DOCS_URL=http://localhost:6011
