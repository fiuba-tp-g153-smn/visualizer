# Production environment variables
# Copy this file to .env.production and adjust values for production

# Data Service API base URL (tiles and product metadata)
DATA_SERVICE_BASE_URL=http://localhost:6006

# Alerts Service API base URL (polygon operations and departments)
ALERTS_SERVICE_BASE_URL=http://localhost:6007

# SMN weather stations: API key issued via the data-service admin endpoints.
# Not a secret (visible in the bundle); rotate via the admin endpoints if leaked.
WEATHER_STATIONS_API_KEY=

# Whether to prompt the user for an API token (true/false)
SMN_API_PROMPT_FOR_TOKEN=true

# App host port (the exposed port of the server)
APP_HOST_PORT=6010

# Docs Service
DOCS_HOST_PORT=6011
DOCS_URL=http://localhost:6011

# Metrics Service API base URL (tiles-processor backoffice performance dashboard)
METRICS_SERVICE_BASE_URL=http://localhost:6020

# Place search (experimental "Explorar mapa" feature) — third-party gazetteer endpoints
IGN_PLACE_SEARCH_URL=https://api.ign.gob.ar/buscador/search
NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
