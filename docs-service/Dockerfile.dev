# Build stage
FROM node:22-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose port 3000 (Docusaurus default)
EXPOSE 3000

# Serve the application
CMD [ "npm", "start", "--", "--host", "0.0.0.0", "--port", "3000" ]
