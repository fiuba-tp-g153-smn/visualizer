# syntax=docker/dockerfile:1

FROM node:24-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies with cache mount, then stamp the lockfile used.
# The stamp lets the dev-compose entrypoint skip reinstalling unless deps change.
RUN --mount=type=cache,target=/root/.npm \
    npm ci \
    && cp package-lock.json node_modules/.deps-installed

# Copy source code
COPY . .

# Expose port 3000 (Docusaurus default)
EXPOSE 3000

# Serve the application
CMD [ "npm", "start", "--", "--host", "0.0.0.0", "--port", "3000" ]
