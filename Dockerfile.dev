# syntax=docker/dockerfile:1

FROM node:24-alpine

# Set working directory
WORKDIR /app

# Build arguments for environment variables
ARG BACKEND_BASE_URL
ARG APP_HOST_PORT

# Set environment variables for build
ENV BACKEND_BASE_URL=$BACKEND_BASE_URL
ENV APP_HOST_PORT=$APP_HOST_PORT

# Copy package files
COPY package*.json ./

# Install dependencies with cache mount, then stamp the lockfile used.
# The stamp lets the dev-compose entrypoint skip reinstalling unless deps change.
RUN --mount=type=cache,target=/root/.npm \
    npm ci \
    && cp package-lock.json node_modules/.deps-installed

# Copy source code
COPY . .

EXPOSE 4200

# Serve the application
CMD [ "npm", "start", "--", "--host", "0.0.0.0" ]
